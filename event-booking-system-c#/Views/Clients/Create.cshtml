@model event_booking_system_c_.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<!-- Optional shallow banner/header for consistency with dashboard -->
<div class="position-relative mb-5 overflow-hidden rounded-4 shadow mt-5" 
     style="height: 180px;" 
     data-aos="fade">
    <div class="position-absolute top-10 start-10 w-100 h-100 bg-dark opacity-60"></div>
    <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
         alt="Modern workspace team" 
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.9) contrast(1.05);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="300">
        <h1 class="display-5 fw-bold drop-shadow">Add New Client</h1>
        <p class="lead opacity-90 mb-0">Register a new attendee or organizer</p>
    </div>
</div>

<div class="container" style="max-width: 700px;">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" data-aos="fade-up" data-aos-duration="900">
        <div class="card-header text-white py-4 text-center"
             style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
            <h3 class="mb-0 fw-bold">New Client Registration</h3>
        </div>

        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <!-- Full Name -->
                <div class="mb-4">
                    <label asp-for="FullName" class="form-label fw-medium text-muted">Full Name</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-person-fill text-primary"></i>
                        </span>
                        <input asp-for="FullName" class="form-control form-control-lg rounded-pill" 
                               placeholder="John Doe" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <!-- Email Address -->
                <div class="mb-5">
                    <label asp-for="EmailAddress" class="form-label fw-medium text-muted">Email Address</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-envelope-fill text-primary"></i>
                        </span>
                        <input asp-for="EmailAddress" class="form-control form-control-lg rounded-pill" 
                               type="email" placeholder="name@example.com" required />
                    </div>
                    <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                </div>

                <!-- Optional: Add more fields like Phone, Password if this is also for user registration -->
                <!-- Example: Phone Number -->
                <!--
                <div class="mb-4">
                    <label class="form-label fw-medium text-muted">Phone Number</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-telephone-fill text-primary"></i>
                        </span>
                        <input class="form-control form-control-lg rounded-pill" placeholder="+27 82 123 4567" />
                    </div>
                </div>
                -->

                <!-- Submit & Cancel -->
                <div class="d-flex gap-3 justify-content-center mt-5">
                    <button type="submit" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow hover-lift">
                        <i class="bi bi-person-plus me-2"></i> Create Client
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 py-3 rounded-pill">
                        Cancel
                    </a>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light text-center py-3 border-0">
            <small class="text-muted">
                All new clients will receive a welcome email with event updates.
            </small>
        </div>
    </div>
</div>


}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <!-- Optional: If you want client-side focus animation or something extra -->
}