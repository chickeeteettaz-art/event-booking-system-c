@model event_booking_system_c_.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<!-- Shallow banner header for consistency -->
<div class="position-relative mb-5 mt-5 overflow-hidden rounded-4 shadow"
     style="height: 180px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-60"></div>
    <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
         alt="Modern professional team"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.9) contrast(1.05);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="300">
        <h1 class="display-5 fw-bold drop-shadow">Client Profile</h1>
        <p class="lead opacity-90 mb-0">View detailed information</p>
    </div>
</div>

<div class="container" style="max-width: 800px;">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4" data-aos="fade-up" data-aos-duration="900">
        <!-- Profile Header -->
        <div class="card-header text-white py-5 text-center position-relative"
             style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
            <div class="avatar-circle mx-auto mb-3 bg-white rounded-circle shadow d-flex align-items-center justify-content-center overflow-hidden"
                 style="width: 140px; height: 140px; border: 6px solid rgba(255,255,255,0.3);">
                <img src="https://thumbs.dreamstime.com/b/african-american-woman-vector-illustration-dark-skin-voluminous-curly-hair-minimalist-design-ideal-profile-diversity-439897163.jpg"
                     alt="Client Avatar"
                     class="w-100 h-100 object-fit-cover" />
            </div>
            <h3 class="mb-1 fw-bold">@Html.DisplayFor(model => model.FullName)</h3>
            <p class="mb-0 opacity-90 fs-5">
                <i class="bi bi-envelope-fill me-2"></i>
                @Html.DisplayFor(model => model.EmailAddress)
            </p>
        </div>

        <!-- Details Section -->
        <div class="card-body p-4 p-md-5 bg-white">
            <h4 class="fw-bold mb-4 text-center text-muted border-bottom pb-3"
                style="border-color: #ff6b35 !important;">
                Client Information
            </h4>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="info-item p-4 rounded-3 bg-light shadow-sm">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="icon-circle bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-4"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Full Name</small>
                                <h5 class="mb-0 fw-medium">@Html.DisplayFor(model => model.FullName)</h5>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-item p-4 rounded-3 bg-light shadow-sm">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="icon-circle bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px;">
                                <i class="bi bi-envelope-fill fs-4"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Email Address</small>
                                <h5 class="mb-0 fw-medium">@Html.DisplayFor(model => model.EmailAddress)</h5>
                            </div>
                        </div>
                    </div>
                </div>

               
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-center gap-4 mt-5 flex-wrap">
                <a asp-action="Edit" asp-route-id="@Model?.ClientId"
                   class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow hover-lift">
                    <i class="bi bi-pencil me-2"></i> Edit Client
                </a>
                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-lg px-5 py-3 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

