@model event_booking_system_c_.Models.Client

@{
    ViewData["Title"] = "Client Details";
    // Assume you pass the full list of clients to the view via ViewBag or a ViewModel property
    // Example: ViewBag.AllClients = allClients; (IEnumerable<Client>)
    var allClients = ViewBag.AllClients as IEnumerable<event_booking_system_c_.Models.Client> ?? Enumerable.Empty<event_booking_system_c_.Models.Client>();
}

<!-- Banner Header (full width) -->
<div class="position-relative mb-4 overflow-hidden rounded-4 shadow-sm mt-5"
     style="height: 160px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-65"></div>
    <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
         alt="Modern professional team"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.9) contrast(1.05);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="250">
        <h2 class="fw-bold mb-1 drop-shadow">Client Profile</h2>
        <p class="mb-0 opacity-90">View and manage client information</p>
    </div>
</div>

<div class="container-fluid px-3 px-lg-4">
    <div class="row g-4">
        <!-- Left Column: List of All Clients -->
        <div class="col-lg-4">
            <div class="card border-0 shadow rounded-4 overflow-hidden h-100">
                <div class="card-header text-white py-3 text-center"
                     style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
                    <h5 class="mb-0 fw-bold">All Clients</h5>
                    <small class="opacity-90">@allClients.Count() registered</small>
                </div>
                <div class="card-body p-0" style="max-height: 65vh; overflow-y: auto;">
                    <div class="list-group list-group-flush">
                        @if (!allClients.Any())
                        {
                            <div class="list-group-item text-center text-muted py-5">
                                <i class="bi bi-people-fill fs-1 opacity-50 d-block mb-3"></i>
                                No clients yet
                            </div>
                        }
                        else
                        {
                            @foreach (var client in allClients)
                            {
                                var isActive = client.ClientId == Model.ClientId;
                                <a asp-action="Details" asp-route-id="@client.ClientId"
                                   class="list-group-item list-group-item-action px-4 py-3 @(isActive ? "active bg-gradient text-white" : "")"
                                   style="@(isActive ? "background: linear-gradient(135deg, #ff8c5e 0%, #ff5e2e 100%) !important; border-color: transparent;" : "")">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-white rounded-circle p-2 d-flex align-items-center justify-content-center"
                                             style="width: 48px; height: 48px;">
                                            <i class="bi bi-person-fill text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-medium">@client.FullName</h6>
                                            <small class="@(isActive ? "text-white-75" : "text-muted")">@client.EmailAddress</small>
                                        </div>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Selected Client Details -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" data-aos="fade-up" data-aos-duration="900">
                <!-- Profile Header -->
                <div class="card-header text-white py-5 text-center position-relative"
                     style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
                    <div class="avatar-circle mx-auto mb-3 bg-white rounded-circle shadow d-flex align-items-center justify-content-center overflow-hidden"
                         style="width: 140px; height: 140px; border: 6px solid rgba(255,255,255,0.3);">
                        <img src="https://thumbs.dreamstime.com/b/african-american-woman-vector-illustration-dark-skin-voluminous-curly-hair-minimalist-design-ideal-profile-diversity-439897163.jpg"
                             alt="Client Avatar"
                             class="w-100 h-100 object-fit-cover" />
                    </div>
                    <h3 class="mb-1 fw-bold">@Html.DisplayFor(model => model.FullName)</h3>
                    <p class="mb-0 opacity-90 fs-5">
                        <i class="bi bi-envelope-fill me-2"></i>
                        @Html.DisplayFor(model => model.EmailAddress)
                    </p>
                </div>

                <!-- Details Section -->
                <div class="card-body p-4 p-md-5 bg-white">
                    <h4 class="fw-bold mb-4 text-center text-muted border-bottom pb-3"
                        style="border-color: #ff6b35 !important;">
                        Client Information
                    </h4>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-item p-4 rounded-3 bg-light shadow-sm">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="icon-circle bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                         style="width: 50px; height: 50px;">
                                        <i class="bi bi-person-fill fs-4"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Full Name</small>
                                        <h5 class="mb-0 fw-medium">@Html.DisplayFor(model => model.FullName)</h5>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-item p-4 rounded-3 bg-light shadow-sm">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="icon-circle bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                         style="width: 50px; height: 50px;">
                                        <i class="bi bi-envelope-fill fs-4"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Email Address</small>
                                        <h5 class="mb-0 fw-medium">@Html.DisplayFor(model => model.EmailAddress)</h5>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Add more fields here if your model has them -->
                    </div>

                    <!-- Actions -->
                    <div class="d-flex justify-content-center gap-4 mt-5 flex-wrap">
                        <a asp-action="Edit" asp-route-id="@Model?.ClientId"
                           class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow hover-lift">
                            <i class="bi bi-pencil me-2"></i> Edit Client
                        </a>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary btn-lg px-5 py-3 rounded-pill">
                            <i class="bi bi-arrow-left me-2"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
