@model event_booking_system_c_.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<!-- Banner Header -->
<div class="position-relative mb-4 overflow-hidden rounded-4 shadow-sm mt-5"
     style="height: 160px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-65"></div>
    <img src="https://images.unsplash.com/photo-1556155099-490a1ba16284?auto=format&fit=crop&q=80&w=2400"
         alt="Modern professional workspace"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.92) contrast(1.08);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="250">
        <h2 class="display-5 fw-bold drop-shadow">Delete Client</h2>
        <p class="mb-0 opacity-90">Confirmation required</p>
    </div>
</div>

<div class="container" style="max-width: 580px;">
    <div class="card border-0 shadow rounded-4 overflow-hidden mb-4" data-aos="fade-up" data-aos-duration="800">
        <div class="card-header text-white py-3 text-center"
             style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
            <h4 class="mb-1 fw-bold">Confirm Deletion</h4>
            <small class="opacity-90">@Model.FullName</small>
        </div>

        <div class="card-body p-4 text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger display-4 d-block mb-3"></i>
                <h5 class="fw-bold text-danger mb-2">Are you sure?</h5>
                <p class="text-muted mb-0">
                    You are about to permanently delete this client:<br />
                    <strong>@Html.DisplayFor(model => model.FullName)</strong><br />
                    <small>(@Html.DisplayFor(model => model.EmailAddress))</small>
                </p>
                <p class="text-muted small mt-3">
                    This action cannot be undone.
                </p>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="ClientId" />

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <button type="submit"
                            class="btn btn-danger rounded-pill fw-bold shadow hover-lift-danger">
                        <i class="bi bi-trash-fill me-2"></i> Yes, Delete Client
                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light text-center py-3 border-0 small text-muted">
            Pretoria, Gauteng • Action will be logged
        </div>
    </div>
</div>

