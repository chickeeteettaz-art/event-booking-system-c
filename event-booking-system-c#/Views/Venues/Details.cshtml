@model event_booking_system_c_.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<!-- Shallow banner (consistent with other pages) -->
<div class="position-relative mb-5 overflow-hidden rounded-4 shadow-sm mt-5"
     style="height: 160px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-65"></div>
    <img src="https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&q=80&w=2400"
         alt="Modern event venue"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.9) contrast(1.08);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="250">
        <h2 class="fw-bold mb-1 drop-shadow">Venue Details</h2>
        <p class="mb-0 opacity-90">@Model.Name</p>
    </div>
</div>

<div class="container" style="max-width: 1100px;">
    <div class="row g-5">
        <!-- Left: Large Venue Image -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" data-aos="fade-right">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl"
                         alt="@Model.Name"
                         class="w-100 rounded-4"
                         style="height: 520px; object-fit: cover; object-position: center;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center text-muted"
                         style="height: 520px; font-size: 5rem;">
                        <i class="bi bi-building"></i>
                    </div>
                }

                <!-- Capacity badge overlay -->
                <span class="position-absolute bottom-0 start-0 m-4 badge bg-dark fs-5 px-4 py-2">
                    Capacity: @Model.Capacity people
                </span>
            </div>
        </div>

        <!-- Right: Details -->
        <div class="col-lg-5">
            <div class="card border-0 shadow rounded-4 p-4 p-lg-5 bg-white" data-aos="fade-left">
                <h3 class="fw-bold mb-4" style="color: var(--primary);">
                    @Model.Name
                </h3>

                <div class="mb-4">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                             style="width: 48px; height: 48px;">
                            <i class="bi bi-geo-alt-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Location</small>
                            <h5 class="mb-0">@Model.Location</h5>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                             style="width: 48px; height: 48px;">
                            <i class="bi bi-people-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Capacity</small>
                            <h5 class="mb-0">@Model.Capacity people</h5>
                        </div>
                    </div>
                </div>

                <div class="mb-5">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                             style="width: 48px; height: 48px;">
                            <i class="bi bi-tags-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Type</small>
                            <h5 class="mb-0">@(Model.VenueType?.Title ?? "Not specified")</h5>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 flex-wrap mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.VenueId"
                       class="btn btn-primary btn-lg px-5 rounded-pill fw-semibold shadow-sm hover-lift">
                        <i class="bi bi-pencil me-2"></i> Edit Venue
                    </a>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


}