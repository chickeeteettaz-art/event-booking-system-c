@model event_booking_system_c_.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<!-- Banner Header -->
<div class="position-relative mb-4 overflow-hidden rounded-4 shadow-sm mt-5"
     style="height: 160px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-65"></div>
    <img src="https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&q=80&w=2400"
         alt="Modern event venue"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.9) contrast(1.08);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="250">
        <h2 class="fw-bold mb-1 drop-shadow">Delete Venue</h2>
        <p class="mb-0 opacity-90">Confirmation required</p>
    </div>
</div>

<div class="container" style="max-width: 620px;">
    <div class="card border-0 shadow rounded-4 overflow-hidden" data-aos="fade-up" data-aos-duration="800">
        <div class="card-header text-white py-3 text-center"
             style="background: linear-gradient(135deg, #ff6b35 0%, #e55a2d 100%);">
            <h4 class="mb-1 fw-bold">Confirm Deletion</h4>
            <small class="opacity-90">@Model.Name</small>
        </div>

        <div class="card-body p-4 p-md-5 text-center">
            <div class="mb-5">
                <i class="bi bi-exclamation-triangle-fill text-danger display-3 d-block mb-4"></i>

                <h5 class="fw-bold text-danger mb-3">
                    Are you sure you want to delete this venue?
                </h5>

                <p class="text-muted mb-1">
                    <strong>@Model.Name</strong>
                </p>
                <p class="text-muted small mb-4">
                    @Model.Location • Capacity: @Model.Capacity people
                </p>

                <div class="alert alert-warning small mb-4" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    This action <strong>cannot be undone</strong>. All related event bookings and data will be permanently removed.
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="VenueId" />

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <button type="submit"
                            class="btn btn-danger rounded-pill fw-bold shadow hover-lift-danger">
                        <i class="bi bi-trash-fill me-2"></i> Yes, Delete Venue
                    </button>

                    <a asp-action="Details" asp-route-id="@Model.VenueId"
                       class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-eye me-2"></i> View Details
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Cancel / Back to List
                    </a>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light text-center py-3 border-0 small text-muted">
            Pretoria, Gauteng • This action will be logged
        </div>
    </div>
</div>
