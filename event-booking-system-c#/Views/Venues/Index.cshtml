@model IEnumerable<event_booking_system_c_.Models.Venue>

@{
    ViewData["Title"] = "Venues Dashboard";
}

<!-- Banner Header -->
<div class="position-relative mb-5 overflow-hidden rounded-4 shadow-sm mt-5"
     style="height: 180px;"
     data-aos="fade">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-60"></div>
    <img src="https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&q=80&w=2400"
         alt="Modern event venue stage"
         class="w-100 h-100 object-fit-cover"
         style="filter: brightness(0.88) contrast(1.1);" />
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white z-1"
         data-aos="fade-up" data-aos-delay="300">
        <h1 class="display-5 fw-bold drop-shadow">Venues Dashboard</h1>
        <p class="lead opacity-90 mb-0">Manage event spaces & locations</p>
    </div>
</div>

<div class="container-fluid px-3 px-lg-4">
    <!-- Header with Add button -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3"
         data-aos="fade-down">
        <h2 class="mb-0 fw-bold text-dark">
            All Venues
            <span class="badge bg-primary ms-2 fs-6">@Model.Count()</span>
        </h2>
        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow hover-lift">
            <i class="bi bi-plus-lg me-2"></i> Add New Venue
        </a>
    </div>

    <!-- Venues Grid -->
    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5 my-5 rounded-4" data-aos="fade-up">
            <i class="bi bi-building-fill-gear display-1 d-block mb-3 opacity-50"></i>
            <h4>No venues added yet</h4>
            <p class="lead">Click "Add New Venue" to get started.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mb-5">

            @foreach (var item in Model)
            {
                <div class="col" data-aos="fade-up" data-aos-duration="700">
                    <div class="card venue-card h-100 border-0 shadow rounded-4 overflow-hidden">
                        <div class="position-relative">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl"
                                     alt="@item.Name"
                                     class="card-img-top"
                                     style="height: 220px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center"
                                     style="height: 220px;">
                                    <i class="bi bi-building fs-1 text-muted"></i>
                                </div>
                            }

                            <span class="position-absolute top-0 end-0 m-3 badge bg-dark fs-6 px-3 py-2">
                                @item.Capacity people
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold mb-2">@item.Name</h5>
                            <p class="card-text text-muted small mb-3">
                                <i class="bi bi-geo-alt-fill me-1 text-primary"></i>
                                @item.Location
                            </p>

                            <div class="mt-auto">
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-warning text-dark">
                                        @(item.VenueType?.Title ?? "Uncategorized")
                                    </span>
                                </div>

                                <div class="mt-4 d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.VenueId"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-3 flex-grow-1">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.VenueId"
                                       class="btn btn-outline-secondary btn-sm rounded-pill px-3 flex-grow-1">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.VenueId"
                                       class="btn btn-outline-danger btn-sm rounded-pill px-3 flex-grow-1">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>

